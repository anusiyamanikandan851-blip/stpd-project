# Neon Postgres connection string. Get this from the Neon dashboard.
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxxx.aws.neon.tech/neondb?sslmode=require

# Generate a strong secret. Used to sign JWTs.
JWT_SECRET_KEY=change-me-to-a-long-random-string

# Stripe (optional, only if you use payments)
STRIPE_SECRET_KEY=sk_test_xxx

# OpenRouter (optional, only if you use the chatbot)
OPENROUTER_API_KEY=sk-or-xxx

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# Render sets PORT automatically; only used locally
PORT=5000
